# Widget Visibility Tests Configuration

# =============================================================================
# Таймауты
# =============================================================================

# Таймаут ожидания виджета (мс)
WIDGET_TIMEOUT=30000

# Минимальный размер виджета в пикселях
MIN_WIDGET_SIZE=30

# Ожидаемое количество iframe (основной + медалька)
EXPECTED_IFRAME_COUNT=2

# Общий таймаут теста (мс)
TEST_TIMEOUT=60000

# =============================================================================
# Партнёры (опционально)
# =============================================================================
# Если не задано — используются партнёры по умолчанию из config.js
# Формат: JSON-массив объектов {"name": "...", "url": "..."}

# Пример: один партнёр
# PARTNERS=[{"name":"My Partner","url":"https://example.com/index.html"}]

# Пример: несколько партнёров
# PARTNERS=[{"name":"Partner 1","url":"https://example.com/p1"},{"name":"Partner 2","url":"https://example.com/p2"}]
